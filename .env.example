# Copy to .env and fill in real values. .env is gitignored — never commit it,
# and never paste real values into chats, issues, or logs.
# All values below are placeholders/defaults, not real credentials.

# --- Phase 1: ingestion (no auth needed; polite-crawling knobs only) ---
NBA_WINPROB_RAW_DATA_DIR=data/raw
NBA_WINPROB_MIN_REQUEST_INTERVAL=1.0

# --- Phase 2: streaming pipeline ---
NBA_WINPROB_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
NBA_WINPROB_KAFKA_EVENTS_TOPIC=nba.game.events
NBA_WINPROB_KAFKA_FEATURES_TOPIC=nba.game.features
NBA_WINPROB_KAFKA_CONSUMER_GROUP=nba-winprob-processor
NBA_WINPROB_LIVE_POLL_INTERVAL=15.0

# --- Phase 3+: feature store / ML (uncomment as those services come online) ---
# NBA_WINPROB_REDIS_URL=redis://localhost:6379/0
# NBA_WINPROB_POSTGRES_DSN=postgresql://USER:CHANGE_ME@localhost:5432/nba_winprob
# NBA_WINPROB_MLFLOW_TRACKING_URI=http://localhost:5000
